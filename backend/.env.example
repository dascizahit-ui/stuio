# Bu dosyayı .env olarak kopyalayıp değerleri doldurun.

# Oturum/çerez imzalama anahtarı — UZUN ve RASTGELE olmalı (üretimde mutlaka değiştirin)
SECRET_KEY=degistir-bunu-uzun-rastgele-bir-deger

# Veritabanı (varsayılan SQLite). Postgres örneği:
# DATABASE_URL=postgresql+psycopg2://kullanici:sifre@localhost:5432/zette
DATABASE_URL=sqlite:///./zette.db

# İlk admin kullanıcı (sadece seed sırasında kullanılır)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=guclu-bir-sifre-girin
